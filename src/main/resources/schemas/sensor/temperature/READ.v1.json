{
  "$id": "sensor.temperature.read.v1",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "SensorRead(v1)",
  "description": "Read a single sensor by its ROM address",
  "required": ["macAddress", "requestId", "command", "sensorAddress"],
  "properties": {
    "command":       {"type": "string", "title": "Command", "description": "Sensor command id (READ)"},
    "requestId":     {"type": "string", "title": "RequestId", "description": "Request correlation id"},
    "macAddress":    {"type": "string", "title": "MacAddressESP", "description": "Target controller MAC (or wildcard)"},
    "sensorAddress": {"type": "string", "title": "SensorAddress", "description": "1-Wire ROM address of the sensor"}
  },
  "additionalProperties": false
}
